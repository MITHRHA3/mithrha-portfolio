# Server runtime configuration port
PORT=5000

# MongoDB Atlas connection string URI
# Replace <username>, <password>, and <database> with your Atlas cluster details
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/<database>?retryWrites=true&w=majority

# Secret phrase used to sign and verify JWT authorization tokens
# Ensure this is a strong random key in production
JWT_SECRET=super_secret_jwt_hash_key_for_mithrha_portfolio
